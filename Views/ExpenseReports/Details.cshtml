@model ExpenseReportDetailsPage

@{
    ViewData["Title"] = Model.Report.Title;
    var canEdit = Model.Report.Status is ExpenseReportStatus.Draft or ExpenseReportStatus.Returned;
}

<div class="mb-3">
    <a asp-action="Index">返回列表</a>
</div>

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="d-flex align-items-start justify-content-between mb-4">
    <div>
        <h1 class="h3 mb-1">@Model.Report.Title</h1>
        <div class="text-muted">申請人：@Model.Report.ApplicantName</div>
    </div>
    <div class="text-end">
        <div class="badge bg-secondary mb-2">@StatusText(Model.Report.Status)</div>
        <div class="fs-4">@Model.Report.TotalAmount.ToString("N2")</div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <h2 class="h5 mb-0">明細</h2>
            @if (canEdit && Model.Report.Details.Count > 0)
            {
                <form asp-action="Submit" asp-route-id="@Model.Report.Id" method="post">
                    <button type="submit" class="btn btn-success btn-sm">送審</button>
                </form>
            }
        </div>

        @if (Model.Report.Details.Count == 0)
        {
            <div class="alert alert-secondary">尚未加入明細。</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>日期</th>
                            <th>類別</th>
                            <th>說明</th>
                            <th class="text-end">金額</th>
                            @if (canEdit)
                            {
                                <th></th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var detail in Model.Report.Details)
                    {
                        <tr>
                            <td>@detail.ExpenseDate.ToString("yyyy/MM/dd")</td>
                            <td>@detail.Category</td>
                            <td>@detail.Description</td>
                            <td class="text-end">@detail.Amount.ToString("N2")</td>
                            @if (canEdit)
                            {
                                <td class="text-end">
                                    <form asp-action="RemoveDetail" asp-route-id="@Model.Report.Id" asp-route-detailId="@detail.Id" method="post">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">移除</button>
                                    </form>
                                </td>
                            }
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="col-lg-4">
        @if (canEdit)
        {
            <h2 class="h5 mb-3">新增明細</h2>
            <form asp-action="AddDetail" asp-route-id="@Model.Report.Id" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="NewDetail.ExpenseDate" class="form-label">日期</label>
                    <input asp-for="NewDetail.ExpenseDate" type="date" class="form-control" />
                    <span asp-validation-for="NewDetail.ExpenseDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NewDetail.Category" class="form-label">類別</label>
                    <input asp-for="NewDetail.Category" class="form-control" autocomplete="off" />
                    <span asp-validation-for="NewDetail.Category" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NewDetail.Description" class="form-label">說明</label>
                    <input asp-for="NewDetail.Description" class="form-control" autocomplete="off" />
                    <span asp-validation-for="NewDetail.Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NewDetail.Amount" class="form-label">金額</label>
                    <input asp-for="NewDetail.Amount" class="form-control" inputmode="decimal" />
                    <span asp-validation-for="NewDetail.Amount" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">加入明細</button>
            </form>
        }
        else
        {
            <div class="alert alert-info">報銷單送審後不可修改明細。</div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@functions {
    private static string StatusText(ExpenseReportStatus status) => status switch
    {
        ExpenseReportStatus.Draft => "草稿",
        ExpenseReportStatus.Submitted => "送審中",
        ExpenseReportStatus.Returned => "退回",
        ExpenseReportStatus.Approved => "已核准",
        ExpenseReportStatus.Rejected => "已拒絕",
        _ => status.ToString()
    };
}

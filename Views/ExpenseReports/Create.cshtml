@model CreateExpenseReportForm

@{
    ViewData["Title"] = "新增報銷單";
}

<div class="mb-3">
    <a asp-action="Index">返回列表</a>
</div>

<h1 class="h3 mb-3">新增報銷單</h1>

<form asp-action="Create" method="post" class="col-lg-6">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label">標題</label>
        <input asp-for="Title" class="form-control" autocomplete="off" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ApplicantName" class="form-label">申請人</label>
        <input asp-for="ApplicantName" class="form-control" autocomplete="off" />
        <span asp-validation-for="ApplicantName" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">建立</button>
    <a class="btn btn-outline-secondary" asp-action="Index">取消</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

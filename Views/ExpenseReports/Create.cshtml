@model CreateExpenseReportForm

@{
    ViewData["Title"] = "新增報銷單";
}

<div class="mb-3">
    <a asp-action="Index">返回列表</a>
</div>

<h1 class="h3 mb-3">新增報銷單</h1>

<form asp-action="Create" method="post" class="col-lg-6">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label">標題</label>
        <input asp-for="Title" class="form-control" autocomplete="off" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ApplicantName" class="form-label">申請人</label>
        <input asp-for="ApplicantName" class="form-control" autocomplete="off" />
        <span asp-validation-for="ApplicantName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ExpenseType" class="form-label">支出類型</label>
        <select asp-for="ExpenseType" class="form-select">
            <option value="@ExpenseType.General">一般支出</option>
            <option value="@ExpenseType.Project">專案支出</option>
        </select>
        <span asp-validation-for="ExpenseType" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ProjectId" class="form-label">專案</label>
        <select asp-for="ProjectId" class="form-select">
            <option value="">不連到專案</option>
            @foreach (var project in Model.ProjectOptions)
            {
                <option value="@project.Id">@project.Name - @project.CustomerName</option>
            }
        </select>
        <div class="form-text">只有支出類型為專案支出時需要選擇。</div>
        <span asp-validation-for="ProjectId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PaymentMethod" class="form-label">付款方式</label>
        <select asp-for="PaymentMethod" class="form-select">
            <option value="@ExpensePaymentMethod.EmployeePaid">員工墊款</option>
            <option value="@ExpensePaymentMethod.CashAdvance">預支費用</option>
        </select>
        <span asp-validation-for="PaymentMethod" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CashAdvanceId" class="form-label">對應預支款</label>
        <select asp-for="CashAdvanceId" class="form-select">
            <option value="">不使用預支款</option>
            @foreach (var cashAdvance in Model.CashAdvanceOptions)
            {
                <option value="@cashAdvance.Id">
                    @cashAdvance.AdvancedAt.ToString("yyyy/MM/dd") -
                    @cashAdvance.PayeeName -
                    @cashAdvance.Purpose -
                    @cashAdvance.Amount.ToString("N2")
                </option>
            }
        </select>
        <div class="form-text">只有付款方式為預支費用時需要選擇。</div>
        <span asp-validation-for="CashAdvanceId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">建立</button>
    <a class="btn btn-outline-secondary" asp-action="Index">取消</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model ProjectListPageDto

@{
    ViewData["Title"] = "專案";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-1">專案</h1>
        <div class="text-muted">專案支出報銷單會連到這裡的專案資料</div>
    </div>
    <a class="btn btn-primary" asp-action="Create">新增專案</a>
</div>

<form asp-action="Index" method="get" class="d-flex gap-2 mb-3">
    <input type="search"
           name="keyword"
           value="@Model.Keyword"
           class="form-control"
           placeholder="搜尋專案名稱、客戶、狀態"
           aria-label="搜尋專案" />
    <button type="submit" class="btn btn-outline-primary">搜尋</button>
    @if (!string.IsNullOrWhiteSpace(Model.Keyword))
    {
        <a class="btn btn-outline-secondary" asp-action="Index">清除</a>
    }
</form>

@if (!string.IsNullOrWhiteSpace(Model.Keyword))
{
    <div class="text-muted small mb-3">找到 @Model.Projects.Count 筆符合「@Model.Keyword」的專案</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (Model.Projects.Count == 0)
{
    <div class="alert alert-secondary">@EmptyProjectMessage(Model)</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>專案名稱</th>
                    <th>客戶</th>
                    <th>狀態</th>
                    <th class="text-end">未完成報銷單</th>
                    <th>建立時間</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var project in Model.Projects)
            {
                <tr>
                    <td>@project.Name</td>
                    <td>@project.CustomerName</td>
                    <td>@StatusText(project.Status)</td>
                    <td class="text-end">@project.UnfinishedExpenseReportCount</td>
                    <td>@project.CreatedAt.ToLocalTime().ToString("yyyy/MM/dd HH:mm")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@project.Id">檢視</a>
                        @if (project.Status == ProjectStatus.Active && project.UnfinishedExpenseReportCount == 0)
                        {
                            <form asp-action="Close" asp-route-id="@project.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('確定要將這個專案結案嗎？結案後不可再新增該專案支出報銷單。');">
                                <button type="submit" class="btn btn-sm btn-outline-secondary">結案</button>
                            </form>
                        }
                        else if (project.Status == ProjectStatus.Active)
                        {
                            <span class="text-muted small">有未完成報銷單</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@functions {
    private static string StatusText(ProjectStatus status) => status switch
    {
        ProjectStatus.Active => "進行中",
        ProjectStatus.Closed => "已結案",
        _ => status.ToString()
    };

    private static string EmptyProjectMessage(ProjectListPageDto page)
        => page.TotalProjectCount == 0
            ? "目前還沒有專案。"
            : "沒有符合關鍵字的專案。";
}

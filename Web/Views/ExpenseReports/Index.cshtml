@model ExpenseReportListPageDto

@{
    ViewData["Title"] = "報銷單";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-1">報銷單</h1>
        <div class="text-muted">員工墊款與預支費用的申請與追蹤</div>
    </div>
    <a class="btn btn-primary" asp-action="Create">新增報銷單</a>
</div>

<form asp-action="Index" method="get" class="row gy-2 gx-2 align-items-end mb-3">
    <div class="col-12 col-lg-4">
        <label class="form-label" for="keyword">關鍵字</label>
        <input type="search"
               id="keyword"
               name="keyword"
               value="@Model.Keyword"
               class="form-control"
               placeholder="搜尋標題、申請人" />
    </div>
    <div class="col-12 col-md-4 col-lg-2">
        <label class="form-label" for="status">狀態</label>
        <select id="status" name="status" class="form-select">
            <option value="">全部</option>
            <option value="@ExpenseReportStatus.Draft" selected="@(Model.Status == ExpenseReportStatus.Draft)">草稿</option>
            <option value="@ExpenseReportStatus.Submitted" selected="@(Model.Status == ExpenseReportStatus.Submitted)">送審中</option>
            <option value="@ExpenseReportStatus.Returned" selected="@(Model.Status == ExpenseReportStatus.Returned)">退回</option>
            <option value="@ExpenseReportStatus.Approved" selected="@(Model.Status == ExpenseReportStatus.Approved)">已核准</option>
            <option value="@ExpenseReportStatus.Rejected" selected="@(Model.Status == ExpenseReportStatus.Rejected)">已拒絕</option>
        </select>
    </div>
    <div class="col-12 col-md-4 col-lg-2">
        <label class="form-label" for="expenseType">支出類型</label>
        <select id="expenseType" name="expenseType" class="form-select">
            <option value="">全部</option>
            <option value="@ExpenseType.General" selected="@(Model.ExpenseType == ExpenseType.General)">一般支出</option>
            <option value="@ExpenseType.Project" selected="@(Model.ExpenseType == ExpenseType.Project)">專案支出</option>
        </select>
    </div>
    <div class="col-12 col-md-4 col-lg-2">
        <label class="form-label" for="paymentMethod">付款方式</label>
        <select id="paymentMethod" name="paymentMethod" class="form-select">
            <option value="">全部</option>
            <option value="@ExpensePaymentMethod.EmployeePaid" selected="@(Model.PaymentMethod == ExpensePaymentMethod.EmployeePaid)">員工墊款</option>
            <option value="@ExpensePaymentMethod.CashAdvance" selected="@(Model.PaymentMethod == ExpensePaymentMethod.CashAdvance)">預支費用</option>
        </select>
    </div>
    <div class="col-12 col-lg-auto d-flex gap-2">
        <button type="submit" class="btn btn-outline-primary">篩選</button>
        @if (HasFilter(Model))
        {
            <a class="btn btn-outline-secondary" asp-action="Index">清除</a>
        }
    </div>
</form>

@if (HasFilter(Model))
{
    <div class="text-muted small mb-3">找到 @Model.Reports.Count 筆符合篩選的報銷單</div>
}

@if (Model.Reports.Count == 0)
{
    <div class="alert alert-secondary">@EmptyReportMessage(Model)</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>標題</th>
                    <th>申請人</th>
                    <th>支出類型</th>
                    <th>專案</th>
                    <th>付款方式</th>
                    <th>狀態</th>
                    <th class="text-end">總金額</th>
                    <th>建立時間</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var report in Model.Reports)
            {
                <tr>
                    <td>@report.Title</td>
                    <td>@report.ApplicantName</td>
                    <td>@ExpenseTypeText(report.ExpenseType)</td>
                    <td>@DisplayProjectName(report)</td>
                    <td>@PaymentMethodText(report.PaymentMethod)</td>
                    <td>@StatusText(report.Status)</td>
                    <td class="text-end">@report.TotalAmount.ToString("N2")</td>
                    <td>@report.CreatedAt.ToLocalTime().ToString("yyyy/MM/dd HH:mm")</td>
                    <td class="text-end">
                        @if (CanEditReport(report.Status))
                        {
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@report.Id">修改</a>
                        }
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@report.Id">檢視</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@functions {
    private static string StatusText(ExpenseReportStatus status) => status switch
    {
        ExpenseReportStatus.Draft => "草稿",
        ExpenseReportStatus.Submitted => "送審中",
        ExpenseReportStatus.Returned => "退回",
        ExpenseReportStatus.Approved => "已核准",
        ExpenseReportStatus.Rejected => "已拒絕",
        _ => status.ToString()
    };

    private static string PaymentMethodText(ExpensePaymentMethod paymentMethod) => paymentMethod switch
    {
        ExpensePaymentMethod.EmployeePaid => "員工墊款",
        ExpensePaymentMethod.CashAdvance => "預支費用",
        _ => paymentMethod.ToString()
    };

    private static string ExpenseTypeText(ExpenseType expenseType) => expenseType switch
    {
        ExpenseType.General => "一般支出",
        ExpenseType.Project => "專案支出",
        _ => expenseType.ToString()
    };

    private static string DisplayProjectName(ExpenseReportListItemDto report)
        => report.ExpenseType == ExpenseType.Project ? report.ProjectName ?? "(找不到專案)" : "-";

    private static bool CanEditReport(ExpenseReportStatus status)
        => status is ExpenseReportStatus.Draft or ExpenseReportStatus.Returned;

    private static bool HasFilter(ExpenseReportListPageDto page)
        => !string.IsNullOrWhiteSpace(page.Keyword) ||
           page.Status is not null ||
           page.ExpenseType is not null ||
           page.PaymentMethod is not null;

    private static string EmptyReportMessage(ExpenseReportListPageDto page)
        => page.TotalExpenseReportCount == 0
            ? "目前還沒有報銷單。"
            : "沒有符合篩選條件的報銷單。";
}

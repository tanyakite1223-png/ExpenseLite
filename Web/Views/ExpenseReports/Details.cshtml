@model ExpenseReportDetailsPage

@{
    ViewData["Title"] = Model.Report.Title;
    var canEdit = Model.Report.Status is ExpenseReportStatus.Draft or ExpenseReportStatus.Returned;
    var canReview = Model.Report.Status is ExpenseReportStatus.Submitted;
    var isClosedProjectReport = Model.Report.ExpenseType == ExpenseType.Project
        && Model.Report.ProjectStatus == ProjectStatus.Closed;
    var canSubmit = canEdit && Model.Report.Details.Count > 0 && !isClosedProjectReport;
}

<div class="mb-3">
    <a asp-action="Index">返回列表</a>
</div>

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (isClosedProjectReport && canEdit)
{
    <div class="alert alert-warning">這張報銷單連到已結案專案，不可送審。</div>
}

<div class="d-flex align-items-start justify-content-between mb-4">
    <div>
        <h1 class="h3 mb-1">@Model.Report.Title</h1>
        <div class="text-muted">申請人：@Model.Report.ApplicantName</div>
        <div class="text-muted">支出類型：@ExpenseTypeText(Model.Report.ExpenseType)</div>
        <div class="text-muted">專案：@DisplayProjectName(Model.Report)</div>
        <div class="text-muted">付款方式：@PaymentMethodText(Model.Report.PaymentMethod)</div>
    </div>
    <div class="text-end">
        <div class="badge bg-secondary mb-2">@StatusText(Model.Report.Status)</div>
        <div class="fs-4">@Model.Report.TotalAmount.ToString("N2")</div>
        @if (canEdit)
        {
            <a class="btn btn-outline-primary btn-sm mt-2" asp-action="Edit" asp-route-id="@Model.Report.Id">修改報銷單</a>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <h2 class="h5 mb-0">明細</h2>
            @if (canSubmit)
            {
                <form asp-action="Submit" asp-route-id="@Model.Report.Id" method="post">
                    <button type="submit" class="btn btn-success btn-sm">送審</button>
                </form>
            }
        </div>

        @if (Model.Report.Details.Count == 0)
        {
            <div class="alert alert-secondary">尚未加入明細。</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>日期</th>
                            <th>類別</th>
                            <th>說明</th>
                            <th>單據</th>
                            <th>發票號碼</th>
                            <th class="text-end">金額</th>
                            @if (canEdit)
                            {
                                <th></th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var detail in Model.Report.Details)
                    {
                        <tr>
                            <td>@detail.ExpenseDate.ToString("yyyy/MM/dd")</td>
                            <td>@detail.Category</td>
                            <td>@detail.Description</td>
                            <td>@ReceiptTypeText(detail.ReceiptType)</td>
                            <td>@DisplayInvoiceNumber(detail)</td>
                            <td class="text-end">@detail.Amount.ToString("N2")</td>
                            @if (canEdit)
                            {
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a class="btn btn-sm btn-outline-primary"
                                           asp-action="Details"
                                           asp-route-id="@Model.Report.Id"
                                           asp-route-editDetailId="@detail.Id">
                                            修改
                                        </a>
                                        <form asp-action="RemoveDetail" asp-route-id="@Model.Report.Id" asp-route-detailId="@detail.Id" method="post">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">移除</button>
                                        </form>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }

        <h2 class="h5 mt-4 mb-3">審核紀錄</h2>
        @if (Model.Report.ReviewRecords.Count == 0)
        {
            <div class="alert alert-secondary">尚無審核紀錄。</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>時間</th>
                            <th>動作</th>
                            <th>審核人</th>
                            <th>原因</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var review in Model.Report.ReviewRecords)
                    {
                        <tr>
                            <td>@review.ReviewedAt.ToLocalTime().ToString("yyyy/MM/dd HH:mm")</td>
                            <td>@ReviewActionText(review.Action)</td>
                            <td>@review.ReviewerName</td>
                            <td>@DisplayReviewReason(review)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="col-lg-4">
        @if (canEdit)
        {
            @if (Model.EditDetail is not null)
            {
                <h2 class="h5 mb-3">修改明細</h2>
                <form asp-action="UpdateDetail"
                      asp-route-id="@Model.Report.Id"
                      asp-route-detailId="@Model.EditDetail.Id"
                      method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="EditDetail.ExpenseDate" class="form-label">日期</label>
                        <input asp-for="EditDetail.ExpenseDate" name="ExpenseDate" type="date" class="form-control" />
                        <span asp-validation-for="EditDetail.ExpenseDate" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EditDetail.Category" class="form-label">類別</label>
                        <input asp-for="EditDetail.Category" name="Category" class="form-control" autocomplete="off" />
                        <span asp-validation-for="EditDetail.Category" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EditDetail.Description" class="form-label">說明</label>
                        <input asp-for="EditDetail.Description" name="Description" class="form-control" autocomplete="off" />
                        <span asp-validation-for="EditDetail.Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EditDetail.ReceiptType" class="form-label">單據類型</label>
                        <select asp-for="EditDetail.ReceiptType" name="ReceiptType" class="form-select">
                            <option value="@ExpenseReceiptType.Receipt">收據</option>
                            <option value="@ExpenseReceiptType.Invoice">發票</option>
                        </select>
                        <span asp-validation-for="EditDetail.ReceiptType" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EditDetail.InvoiceNumber" class="form-label">發票號碼</label>
                        <input asp-for="EditDetail.InvoiceNumber" name="InvoiceNumber" class="form-control" autocomplete="off" />
                        <div class="form-text">單據類型為發票時必填。</div>
                        <span asp-validation-for="EditDetail.InvoiceNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EditDetail.Amount" class="form-label">金額</label>
                        <input asp-for="EditDetail.Amount" name="Amount" class="form-control" inputmode="decimal" />
                        <span asp-validation-for="EditDetail.Amount" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">儲存明細</button>
                        <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Report.Id">取消</a>
                    </div>
                </form>
            }
            else
            {
                <h2 class="h5 mb-3">新增明細</h2>
                <form asp-action="AddDetail" asp-route-id="@Model.Report.Id" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="NewDetail.ExpenseDate" class="form-label">日期</label>
                        <input asp-for="NewDetail.ExpenseDate" type="date" class="form-control" />
                        <span asp-validation-for="NewDetail.ExpenseDate" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewDetail.Category" class="form-label">類別</label>
                        <input asp-for="NewDetail.Category" class="form-control" autocomplete="off" />
                        <span asp-validation-for="NewDetail.Category" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewDetail.Description" class="form-label">說明</label>
                        <input asp-for="NewDetail.Description" class="form-control" autocomplete="off" />
                        <span asp-validation-for="NewDetail.Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewDetail.ReceiptType" class="form-label">單據類型</label>
                        <select asp-for="NewDetail.ReceiptType" class="form-select">
                            <option value="@ExpenseReceiptType.Receipt">收據</option>
                            <option value="@ExpenseReceiptType.Invoice">發票</option>
                        </select>
                        <span asp-validation-for="NewDetail.ReceiptType" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewDetail.InvoiceNumber" class="form-label">發票號碼</label>
                        <input asp-for="NewDetail.InvoiceNumber" class="form-control" autocomplete="off" />
                        <div class="form-text">單據類型為發票時必填。</div>
                        <span asp-validation-for="NewDetail.InvoiceNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewDetail.Amount" class="form-label">金額</label>
                        <input asp-for="NewDetail.Amount" class="form-control" inputmode="decimal" />
                        <span asp-validation-for="NewDetail.Amount" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">加入明細</button>
                </form>
            }
        }
        else
        {
            <div class="alert alert-info">報銷單送審後不可修改明細。</div>
        }

        @if (canReview)
        {
            <h2 class="h5 mt-4 mb-3">審核處理</h2>
            <form method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Review.ReviewerName" class="form-label">審核人</label>
                    <input asp-for="Review.ReviewerName" name="ReviewerName" class="form-control" autocomplete="off" />
                    <span asp-validation-for="Review.ReviewerName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Review.Reason" class="form-label">退回 / 拒絕原因</label>
                    <textarea asp-for="Review.Reason" name="Reason" class="form-control" rows="4"></textarea>
                    <div class="form-text">退回或拒絕時必填；核准時可留空。</div>
                    <span asp-validation-for="Review.Reason" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <button type="submit"
                            class="btn btn-success btn-sm"
                            formaction="@Url.Action("Approve", new { id = Model.Report.Id })">
                        核准
                    </button>
                    <button type="submit"
                            class="btn btn-outline-secondary btn-sm"
                            formaction="@Url.Action("Return", new { id = Model.Report.Id })">
                        退回
                    </button>
                    <button type="submit"
                            class="btn btn-outline-danger btn-sm"
                            formaction="@Url.Action("Reject", new { id = Model.Report.Id })">
                        拒絕
                    </button>
                </div>
            </form>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@functions {
    private static string StatusText(ExpenseReportStatus status) => status switch
    {
        ExpenseReportStatus.Draft => "草稿",
        ExpenseReportStatus.Submitted => "送審中",
        ExpenseReportStatus.Returned => "退回",
        ExpenseReportStatus.Approved => "已核准",
        ExpenseReportStatus.Rejected => "已拒絕",
        _ => status.ToString()
    };

    private static string PaymentMethodText(ExpensePaymentMethod paymentMethod) => paymentMethod switch
    {
        ExpensePaymentMethod.EmployeePaid => "員工墊款",
        ExpensePaymentMethod.CashAdvance => "預支費用",
        _ => paymentMethod.ToString()
    };

    private static string ExpenseTypeText(ExpenseType expenseType) => expenseType switch
    {
        ExpenseType.General => "一般支出",
        ExpenseType.Project => "專案支出",
        _ => expenseType.ToString()
    };

    private static string DisplayProjectName(ExpenseReportDetailDto report)
        => report.ExpenseType == ExpenseType.Project ? report.ProjectName ?? "(找不到專案)" : "-";

    private static string ReceiptTypeText(ExpenseReceiptType receiptType) => receiptType switch
    {
        ExpenseReceiptType.Receipt => "收據",
        ExpenseReceiptType.Invoice => "發票",
        _ => receiptType.ToString()
    };

    private static string DisplayInvoiceNumber(ExpenseDetailDto detail)
        => detail.ReceiptType == ExpenseReceiptType.Invoice ? detail.InvoiceNumber : "-";

    private static string ReviewActionText(ExpenseReviewAction action) => action switch
    {
        ExpenseReviewAction.Returned => "退回",
        ExpenseReviewAction.Approved => "核准",
        ExpenseReviewAction.Rejected => "拒絕",
        _ => action.ToString()
    };

    private static string DisplayReviewReason(ExpenseReviewRecordDto review)
        => string.IsNullOrWhiteSpace(review.Reason) ? "-" : review.Reason;
}

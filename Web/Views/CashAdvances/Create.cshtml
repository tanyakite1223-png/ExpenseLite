@model CreateCashAdvanceForm

@{
    ViewData["Title"] = "新增預支款";
}

<div class="mb-3">
    <a asp-action="Index">返回列表</a>
</div>

<h1 class="h3 mb-3">新增預支款</h1>

<form asp-action="Create" method="post" class="col-lg-6">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="PayeeName" class="form-label">領款人</label>
        <input asp-for="PayeeName" class="form-control" autocomplete="off" />
        <span asp-validation-for="PayeeName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Purpose" class="form-label">預支用途</label>
        <input asp-for="Purpose" class="form-control" autocomplete="off" />
        <span asp-validation-for="Purpose" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="AdvancedAt" class="form-label">預支日期</label>
        <input asp-for="AdvancedAt" type="date" class="form-control" />
        <span asp-validation-for="AdvancedAt" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Amount" class="form-label">預支金額</label>
        <input asp-for="Amount" class="form-control" inputmode="decimal" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">建立</button>
    <a class="btn btn-outline-secondary" asp-action="Index">取消</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

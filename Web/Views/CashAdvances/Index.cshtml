@model CashAdvanceListPageDto

@{
    ViewData["Title"] = "預支款";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-1">預支款</h1>
        <div class="text-muted">追蹤預支款與已核准報銷金額的核對狀態</div>
    </div>
    <a class="btn btn-primary" asp-action="Create">新增預支款</a>
</div>

<form asp-action="Index" method="get" class="row gy-2 gx-2 align-items-end mb-3">
    <div class="col-12 col-lg-5">
        <label class="form-label" for="keyword">關鍵字</label>
        <input type="search"
               id="keyword"
               name="keyword"
               value="@Model.Keyword"
               class="form-control"
               placeholder="搜尋領款人、用途" />
    </div>
    <div class="col-12 col-md-5 col-lg-3">
        <label class="form-label" for="reconciliationStatus">核對狀態</label>
        <select id="reconciliationStatus" name="reconciliationStatus" class="form-select">
            <option value="">全部</option>
            <option value="@CashAdvanceReconciliationStatus.Unreimbursed" selected="@(Model.ReconciliationStatus == CashAdvanceReconciliationStatus.Unreimbursed)">未結清</option>
            <option value="@CashAdvanceReconciliationStatus.Settled" selected="@(Model.ReconciliationStatus == CashAdvanceReconciliationStatus.Settled)">已對上</option>
            <option value="@CashAdvanceReconciliationStatus.CompanyNeedsToPay" selected="@(Model.ReconciliationStatus == CashAdvanceReconciliationStatus.CompanyNeedsToPay)">公司需補付</option>
            <option value="@CashAdvanceReconciliationStatus.EmployeeNeedsToReturn" selected="@(Model.ReconciliationStatus == CashAdvanceReconciliationStatus.EmployeeNeedsToReturn)">員工需繳回</option>
        </select>
    </div>
    <div class="col-12 col-lg-auto d-flex gap-2">
        <button type="submit" class="btn btn-outline-primary">篩選</button>
        @if (HasFilter(Model))
        {
            <a class="btn btn-outline-secondary" asp-action="Index">清除</a>
        }
    </div>
</form>

@if (HasFilter(Model))
{
    <div class="text-muted small mb-3">找到 @Model.CashAdvances.Count 筆符合篩選的預支款</div>
}

@if (Model.CashAdvances.Count == 0)
{
    <div class="alert alert-secondary">@EmptyCashAdvanceMessage(Model)</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>預支日期</th>
                    <th>領款人</th>
                    <th>用途</th>
                    <th class="text-end">預支金額</th>
                    <th class="text-end">已核准報銷</th>
                    <th class="text-end">差額</th>
                    <th>核對狀態</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var cashAdvance in Model.CashAdvances)
            {
                <tr>
                    <td>@cashAdvance.AdvancedAt.ToString("yyyy/MM/dd")</td>
                    <td>@cashAdvance.PayeeName</td>
                    <td>@cashAdvance.Purpose</td>
                    <td class="text-end">@cashAdvance.Amount.ToString("N2")</td>
                    <td class="text-end">@cashAdvance.ApprovedReimbursedAmount.ToString("N2")</td>
                    <td class="text-end">@cashAdvance.Difference.ToString("N2")</td>
                    <td>@ReconciliationText(cashAdvance)</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@functions {
    private static string ReconciliationText(CashAdvanceListItemDto cashAdvance)
        => cashAdvance.ReconciliationStatus switch
        {
            CashAdvanceReconciliationStatus.Unreimbursed => "未結清",
            CashAdvanceReconciliationStatus.Settled => "已對上",
            CashAdvanceReconciliationStatus.CompanyNeedsToPay => "公司需補付",
            CashAdvanceReconciliationStatus.EmployeeNeedsToReturn => "員工需繳回",
            _ => cashAdvance.ReconciliationStatus.ToString()
        };

    private static bool HasFilter(CashAdvanceListPageDto page)
        => !string.IsNullOrWhiteSpace(page.Keyword) ||
           page.ReconciliationStatus is not null;

    private static string EmptyCashAdvanceMessage(CashAdvanceListPageDto page)
        => page.TotalCashAdvanceCount == 0
            ? "目前還沒有預支款。"
            : "沒有符合篩選條件的預支款。";
}
